# ===== Application =====
NODE_ENV=development
PORT=3000
API_PREFIX=/api

# ===== Database =====
DATABASE_URL=postgres://postgres:postgres@localhost:5432/transport_mgmt

# ===== JWT =====
JWT_SECRET=change-me-in-production-use-a-strong-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ===== Frontend =====
FRONTEND_URL=http://localhost:5173
ALLOW_CORS=true
CORS_ORIGIN=*
FRONTEND_CAN_RUN_WITHOUT_API=true
SERVE_FRONTEND=true

# ===== Swagger =====
ENABLE_SWAGGER=true

# ===== Database Bootstrap =====
DB_AUTO_INIT=true
DB_RUN_MIGRATIONS=true
DB_AUTO_CREATE_TABLES=true
DB_DROP_AND_RECREATE=false

# ===== Notifications =====
ENABLE_NOTIFICATIONS=false
ENABLE_SMS=false
ENABLE_WHATSAPP=false

# ===== Communication Channels =====
BREVO_PASSWORD_RESET_API_KEY=your-brevo-password-reset-api-key
BREVO_NOTIFICATION_API_KEY=your-brevo-notification-api-key
BREVO_TRANSPORT_API_KEY=your-brevo-transport-details-api-key

BREVO_SENDER_EMAIL=noreply@dsi-transport.com
BREVO_SENDER_NAME=DSI Transport System

SMS_API_KEY=
SMS_PROVIDER=brevo

WHATSAPP_API_KEY=

# ===== Depot / Origin =====
DEPOT_LAT=6.0477241
DEPOT_LNG=80.2479661

# ===== Vehicle Defaults =====
VAN_CAPACITY=15
BUS_CAPACITY=52
VAN_SOFT_OVERFLOW=4
BUS_SOFT_OVERFLOW=10
MIN_VAN_OCCUPANCY=5
MIN_BUS_OCCUPANCY=15

# ===== Amazon Location Service (V2) =====
AWS_REGION=eu-north-1
AMAZON_LOCATION_API_KEY=
AMAZON_LOCATION_AUTH_MODE=api-key
AMAZON_LOCATION_MAP_STYLE=Standard
AMAZON_LOCATION_ENABLE_MAPS=true
AMAZON_LOCATION_ENABLE_ROUTES=true
AMAZON_LOCATION_ENABLE_TRACKERS=false
AMAZON_LOCATION_ENABLE_GEOFENCES=false
AMAZON_LOCATION_TRACKER_NAME=
AMAZON_LOCATION_GEOFENCE_COLLECTION=
AMAZON_LOCATION_TIMEOUT_MS=10000
